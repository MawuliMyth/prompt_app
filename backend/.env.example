# Server Configuration
PORT=3001
NODE_ENV=development

# API Keys
GROQ_API_KEY=your_groq_api_key
CLAUDE_API_KEY=your_claude_api_key

# Firebase Admin (pick one approach)
# Option 1: full JSON blob on one line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"prompt-5a926","private_key":"-----BEGIN PRIVATE KEY-----\nPASTE_NEW_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-fbsvc@prompt-5a926.iam.gserviceaccount.com"}

# Option 2: individual service account fields
FIREBASE_PROJECT_ID=prompt-5a926
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@prompt-5a926.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Guest usage hashing salt
GUEST_USAGE_SALT=change-me

# URLs (for CORS) - Set this to your production frontend URL when deploying
FRONTEND_URL=http://localhost:5000
